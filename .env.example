# PageYoink Configuration

# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# Authentication
# Comma-separated list of valid API keys. Leave empty to disable auth (dev mode).
API_KEYS=

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Database
# Path to SQLite database file. Defaults to ./data/pageyoink.db
DB_PATH=./data/pageyoink.db

# Puppeteer (set these in Docker/production)
# PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
