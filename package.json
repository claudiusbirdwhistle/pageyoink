{
  "name": "pageyoink",
  "version": "0.1.0",
  "description": "PageYoink — Fast, intelligent screenshot, PDF, and OG image generation API",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'"
  },
  "keywords": [
    "screenshot",
    "pdf",
    "og-image",
    "api",
    "puppeteer"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1014.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@ghostery/adblocker-puppeteer": "^2.14.1",
    "@google-cloud/firestore": "^8.3.0",
    "cross-fetch": "^4.1.0",
    "fastify": "^5.8.2",
    "fastify-plugin": "^5.1.0",
    "pdf-lib": "^1.17.1",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "puppeteer": "^24.40.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/pngjs": "^6.0.5",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
